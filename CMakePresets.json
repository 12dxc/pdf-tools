{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "MSVC x64 (Ninja)",
            "description": "Build with MSVC 2022 using Ninja generator",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_PREFIX_PATH": "C:/Apps/DevToolKit/Qt/6.11.1/msvc2022_64",
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            }
        },
        {
            "name": "release",
            "displayName": "MSVC x64 Release (Ninja)",
            "description": "Release build with optimizations",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "release",
            "configurePreset": "release"
        }
    ]
}
